# Twilio Credentials
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Vonage (Nexmo) Credentials
VONAGE_API_KEY=your_vonage_key
VONAGE_API_SECRET=your_vonage_secret
VONAGE_PHONE_NUMBER=your_vonage_number

# AWS SNS Credentials
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION_NAME=us-east-1

# Plivo Credentials
PLIVO_AUTH_ID=your_plivo_id
PLIVO_AUTH_TOKEN=your_plivo_token
PLIVO_PHONE_NUMBER=your_plivo_number

# Messagebird Credentials
MESSAGEBIRD_API_KEY=your_messagebird_key
MESSAGEBIRD_PHONE_NUMBER=your_messagebird_number

# Telnyx Credentials
TELNYX_API_KEY=your_telnyx_key
TELNYX_PHONE_NUMBER=your_telnyx_number

# Telesign Credentials
TELESIGN_CUSTOMER_ID=your_telesign_id
